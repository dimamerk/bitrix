# Your Bitrix24 portal domain (no trailing slash)
BITRIX24_DOMAIN=https://your-company.bitrix24.com

# OAuth app credentials from Bitrix24 Marketplace > Developer resources
BITRIX24_CLIENT_ID=local.xxxxxxxxxxxxxxxx.xxxxxxxx
BITRIX24_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Better Auth
BETTER_AUTH_SECRET=your-random-secret-at-least-32-characters-long
BETTER_AUTH_URL=http://localhost:3000
